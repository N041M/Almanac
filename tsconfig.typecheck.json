{
  // Pure type-check pass: one program over all package sources, resolving
  // cross-package imports via the base `paths` (→ src). Emits nothing, so
  // `pnpm typecheck` leaves no dist/tsbuildinfo artifacts. The per-package
  // composite configs + root solution file remain for the editor and `tsc -b`.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "noEmit": true
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx"],
  "exclude": ["**/dist/**", "**/node_modules/**"]
}
